# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI Providers (for semantic validation fallback) ───────────────────────────
# OpenRouter (recommended — access to Claude, Llama, Gemini via one key)
OPENROUTER_API_KEY=sk-or-...

# Groq (fast, free tier available)
GROQ_API_KEY=gsk_...

# Google Gemini (alternative)
GEMINI_API_KEY=AIza...

# ── App Config ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NUR Lingo

# AI provider to use: openrouter | groq | gemini
AI_PROVIDER=openrouter
AI_MODEL=anthropic/claude-3-haiku

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_AI_VALIDATION=true
NEXT_PUBLIC_ENABLE_LEADERBOARD=true
NEXT_PUBLIC_ENABLE_STREAKS=true
